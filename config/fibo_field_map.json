{
  "Invoice": {
    "class_uri": "http://example.org/Invoice",
    "fields": [
      {
        "key": "invoice_number",
        "label": "Invoice Number",
        "predicate": "ex:hasInvoiceNumber",
        "pattern": "(Invoice\\s*#[:\\s]*([A-Z0-9\\-]+))"
      },
      {
        "key": "invoice_date",
        "label": "Invoice Date",
        "predicate": "fibo:hasEffectiveDate",
        "pattern": "(Invoice Date[:\\s]*([0-9]{4}-[0-9]{2}-[0-9]{2}|[0-9]{2}/[0-9]{2}/[0-9]{4}))"
      },
      {
        "key": "total_due",
        "label": "Total Due",
        "predicate": "ex:hasTotalDue",
        "pattern": "(Total (Due|Amount)[:\\s]*\\$?([0-9,]+\\.[0-9]{2}))"
      }
    ]
  }
}