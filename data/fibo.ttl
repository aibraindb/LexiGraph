@prefix fibo: <https://spec.edmcouncil.org/fibo/ontology/> .
@prefix fibo-doc: <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/Document/> .
@prefix fibo-fin: <https://spec.edmcouncil.org/fibo/ontology/IND/Finance/> .
@prefix fibo-acc: <https://spec.edmcouncil.org/fibo/ontology/ACC/Accounts/> .
@prefix fibo-org: <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/Organizations/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix ex:   <http://example.org/> .

########## Core Classes ##########
fibo-doc:Document a rdfs:Class ;
  rdfs:label "Document" ;
  skos:definition "An information artifact that records facts, terms, or statements." .

fibo-doc:Agreement a rdfs:Class ;
  rdfs:subClassOf fibo-doc:Document ;
  rdfs:label "Agreement" ;
  skos:definition "Mutual arrangement between parties that creates obligations." .

fibo-doc:FinancialStatement a rdfs:Class ;
  rdfs:subClassOf fibo-doc:Document ;
  rdfs:label "Financial Statement" ;
  skos:definition "A document reporting financial information for a period." .

fibo-doc:TaxDocument a rdfs:Class ;
  rdfs:subClassOf fibo-doc:Document ;
  rdfs:label "Tax Document" ;
  skos:definition "A document pertaining to taxes owed, withheld, or reported." .

########## Specific Doc Types ##########
ex:LeaseAgreement a rdfs:Class ;
  rdfs:subClassOf fibo-doc:Agreement ;
  rdfs:label "Lease Agreement" .

ex:LoanAgreement a rdfs:Class ;
  rdfs:subClassOf fibo-doc:Agreement ;
  rdfs:label "Loan Agreement" .

ex:Invoice a rdfs:Class ;
  rdfs:subClassOf fibo-doc:Document ;
  rdfs:label "Invoice" .

ex:BankStatement a rdfs:Class ;
  rdfs:subClassOf fibo-doc:FinancialStatement ;
  rdfs:label "Bank Statement" .

ex:W2Statement a rdfs:Class ;
  rdfs:subClassOf fibo-doc:TaxDocument ;
  rdfs:label "W-2 Wage and Tax Statement" .

ex:RetirementAccountStatement a rdfs:Class ;
  rdfs:subClassOf fibo-doc:FinancialStatement ;
  rdfs:label "Retirement Account Statement" .

ex:TermDepositCertificate a rdfs:Class ;
  rdfs:subClassOf fibo-doc:Document ;
  rdfs:label "Term Deposit Certificate" .

ex:TaxLevyNotice a rdfs:Class ;
  rdfs:subClassOf fibo-doc:TaxDocument ;
  rdfs:label "Tax Levy Notice" .

########## Parties / Accounts ##########
fibo-org:Party a rdfs:Class ; rdfs:label "Party" .
fibo-org:Organization a rdfs:Class ;
  rdfs:subClassOf fibo-org:Party ;
  rdfs:label "Organization" .
fibo-org:Person a rdfs:Class ;
  rdfs:subClassOf fibo-org:Party ;
  rdfs:label "Person" .

fibo-acc:Account a rdfs:Class ;
  rdfs:label "Account" ;
  skos:definition "A record of financial transactions for a specific entity." .
ex:BankAccount a rdfs:Class ;
  rdfs:subClassOf fibo-acc:Account ;
  rdfs:label "Bank Account" .
ex:RetirementAccount a rdfs:Class ;
  rdfs:subClassOf fibo-acc:Account ;
  rdfs:label "Retirement Account" .

########## Common Properties ##########
fibo:hasDocumentType a rdf:Property ;
  rdfs:label "has document type" ;
  rdfs:domain fibo-doc:Document ;
  rdfs:range rdfs:Class .

fibo:hasIssuer a rdf:Property ;
  rdfs:label "has issuer" ;
  rdfs:domain fibo-doc:Document ;
  rdfs:range fibo-org:Organization .

fibo:hasCounterparty a rdf:Property ;
  rdfs:label "has counterparty" ;
  rdfs:domain fibo-doc:Document ;
  rdfs:range fibo-org:Party .

fibo:hasEffectiveDate a rdf:Property ;
  rdfs:label "has effective date" ;
  rdfs:domain fibo-doc:Document ;
  rdfs:range xsd:date .

fibo:hasMaturityDate a rdf:Property ;
  rdfs:label "has maturity date" ;
  rdfs:domain fibo-doc:Document ;
  rdfs:range xsd:date .

fibo:hasPrincipalAmount a rdf:Property ;
  rdfs:label "has principal amount" ;
  rdfs:domain fibo-doc:Document ;
  rdfs:range xsd:decimal .

fibo:hasInterestRate a rdf:Property ;
  rdfs:label "has interest rate (APR)" ;
  rdfs:domain fibo-doc:Document ;
  rdfs:range xsd:decimal .

ex:hasInvoiceNumber a rdf:Property ;
  rdfs:label "has invoice number" ;
  rdfs:domain ex:Invoice ;
  rdfs:range xsd:string .

ex:hasTotalDue a rdf:Property ;
  rdfs:label "has total due" ;
  rdfs:domain ex:Invoice ;
  rdfs:range xsd:decimal .

ex:relatesToAccount a rdf:Property ;
  rdfs:label "relates to account" ;
  rdfs:domain fibo-doc:Document ;
  rdfs:range fibo-acc:Account .

ex:hasAccountNumber a rdf:Property ;
  rdfs:label "has account number" ;
  rdfs:domain fibo-acc:Account ;
  rdfs:range xsd:string .

ex:hasRoutingNumber a rdf:Property ;
  rdfs:label "has routing number" ;
  rdfs:domain ex:BankAccount ;
  rdfs:range xsd:string .

########## Example Organizations / People ##########
ex:PrimeOfficeLLC a fibo-org:Organization ; rdfs:label "Prime Office LLC" .
ex:EliteImagingLLC a fibo-org:Organization ; rdfs:label "Elite Imaging LLC" .
ex:AcmeBank a fibo-org:Organization ; rdfs:label "ACME Bank" .
ex:AcmeCorp a fibo-org:Organization ; rdfs:label "Acme Corporation" .
ex:JaneDoe a fibo-org:Person ; rdfs:label "Jane A. Doe" .

########## Example Accounts ##########
ex:JaneChecking a ex:BankAccount ;
  rdfs:label "Jane Checking ****1234" ;
  ex:hasAccountNumber "****1234" ;
  ex:hasRoutingNumber "****0210" .

ex:Jane401k a ex:RetirementAccount ;
  rdfs:label "Jane 401(k) 998877" ;
  ex:hasAccountNumber "401K-998877" .

########## Example Documents (instances) ##########
ex:Lease2023 a ex:LeaseAgreement ;
  fibo:hasIssuer ex:PrimeOfficeLLC ;
  fibo:hasCounterparty ex:EliteImagingLLC ;
  fibo:hasEffectiveDate "2023-03-01"^^xsd:date ;
  fibo:hasPrincipalAmount "48000.00"^^xsd:decimal .

ex:Loan2024 a ex:LoanAgreement ;
  fibo:hasIssuer ex:AcmeBank ;
  fibo:hasCounterparty ex:JaneDoe ;
  fibo:hasEffectiveDate "2024-06-01"^^xsd:date ;
  fibo:hasMaturityDate "2034-06-01"^^xsd:date ;
  fibo:hasPrincipalAmount "250000.00"^^xsd:decimal ;
  fibo:hasInterestRate "4.750"^^xsd:decimal .

ex:Invoice0425 a ex:Invoice ;
  fibo:hasIssuer ex:AcmeCorp ;
  fibo:hasCounterparty ex:EliteImagingLLC ;
  ex:hasInvoiceNumber "INV-0425" ;
  ex:hasTotalDue "3045.00"^^xsd:decimal ;
  fibo:hasEffectiveDate "2025-04-10"^^xsd:date .

ex:BankStmtFeb2025 a ex:BankStatement ;
  fibo:hasIssuer ex:AcmeBank ;
  fibo:hasCounterparty ex:JaneDoe ;
  ex:relatesToAccount ex:JaneChecking ;
  fibo:hasEffectiveDate "2025-02-28"^^xsd:date .

ex:W2_2024 a ex:W2Statement ;
  fibo:hasIssuer ex:AcmeCorp ;
  fibo:hasCounterparty ex:JaneDoe ;
  fibo:hasEffectiveDate "2024-12-31"^^xsd:date .

ex:RetirementStmtQ1_2025 a ex:RetirementAccountStatement ;
  fibo:hasIssuer ex:AcmeCorp ;
  fibo:hasCounterparty ex:JaneDoe ;
  ex:relatesToAccount ex:Jane401k ;
  fibo:hasEffectiveDate "2025-03-31"^^xsd:date .

ex:TermDepositCert a ex:TermDepositCertificate ;
  fibo:hasIssuer ex:AcmeBank ;
  fibo:hasCounterparty ex:JaneDoe ;
  fibo:hasEffectiveDate "2024-09-15"^^xsd:date ;
  fibo:hasMaturityDate "2026-09-15"^^xsd:date ;
  fibo:hasPrincipalAmount "25000.00"^^xsd:decimal ;
  fibo:hasInterestRate "4.25"^^xsd:decimal .

ex:TaxLevy2023 a ex:TaxLevyNotice ;
  fibo:hasIssuer ex:AcmeCorp ;
  fibo:hasCounterparty ex:JaneDoe ;
  fibo:hasEffectiveDate "2023-08-01"^^xsd:date .
